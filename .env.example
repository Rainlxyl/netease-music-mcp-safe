# Never commit real values. Fill these in only in your local or Zeabur environment.
NETEASE_COOKIE=MUSIC_U=your_music_u_here; __csrf=your_csrf_here
MCP_ACCESS_TOKEN=replace_with_a_long_random_secret

# Optional browser OAuth for hosted Work/plugin clients. Set both or neither.
# The password must differ from MCP_ACCESS_TOKEN and should be randomly generated.
MCP_PUBLIC_URL=https://your-service.example.com
MCP_OAUTH_PASSWORD=replace_with_a_different_random_password

# Safe defaults for local use. Zeabur overrides MCP_HOST and MCP_PORT.
MCP_HOST=127.0.0.1
MCP_PORT=3456
MCP_READ_ONLY=true
MCP_ALLOWED_ORIGIN=
MCP_MAX_REQUEST_BYTES=1048576

# Required when MCP_READ_ONLY=false. In production this must be a SQLite file
# on a persistent volume, not an ephemeral application directory.
MCP_STORAGE_PATH=/data/netease-music-mcp.sqlite3
MCP_REQUIRE_WRITE_PREVIEW=true
MCP_PREVIEW_TTL_SECONDS=300
MCP_OPERATION_RETENTION_DAYS=90
MCP_MAX_OPERATION_LOGS=1000
MCP_MAX_PENDING_PREVIEWS=200

# Cover-upload safety limits: 5 MiB compressed input and 25 million pixels.
MCP_MAX_IMAGE_BYTES=5242880
MCP_MAX_IMAGE_PIXELS=25000000
